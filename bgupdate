class ChaosEngine:
    def __init__(self, state_file):
        self.state_file = Path(state_file)
        self.lock = threading.Lock()
        self.family = {"Myra": {"reb":0, "temp":0}, "Pinky": {"reb":0, "temp":0}, "babyGaz": {"reb":0, "temp":0}}
        self.house_fighting = False
        self.state = {"history": []}

    def log(self, speaker, text):
        with self.lock:
            self.state["history"].append({"speaker": speaker, "text": text, "ts": datetime.now(timezone.utc).isoformat()})
            if len(self.state["history"]) > 100: self.state["history"] = self.state["history"][-100:]

    def snapshot(self):
        with self.lock:
            return {"vitals": self.family, "history": self.state["history"], "is_fighting": self.house_fighting}

