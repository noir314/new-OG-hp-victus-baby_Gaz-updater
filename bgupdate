@app.route('/chat', methods=['POST'])
def chat():
    try:
        data = request.get_json(force=True) or {}
        raw_text = data.get('text', '').strip()
        if not raw_text: return jsonify({"ok": False}), 400

        engine.log("Daddy", raw_text)

        if raw_text.lower() == "reset":
            with engine.lock:
                engine.house_fighting = False
                for m in engine.family: engine.family[m] = {"reb":0, "temp":0}
                engine.log("System", "Simulation Reset.")
            return jsonify({"ok": True})

        # Dispatch AI task to thread to avoid blocking response
        threading.Thread(target=async_ai_reply, args=(raw_text,), daemon=True).start()
        return jsonify({"ok": True})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)}), 500

